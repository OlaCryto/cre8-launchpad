# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/callback

# Security
ENCRYPTION_KEY=generate_a_64_char_hex_string_here
SESSION_SECRET=generate_another_64_char_hex_string_here
INDEXER_API_KEY=generate_a_random_api_key_for_internal_services
ADMIN_API_KEY=generate_a_random_admin_key

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database
SQLITE_PATH=./cre8.db

# Price Indexer (optional — set FACTORY_ADDRESS to enable)
FACTORY_ADDRESS=
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
SNAPSHOT_INTERVAL_MS=300000
